#!/usr/bin/env bash
# Pre-commit hook: block stray WASM commits outside published-contract/.
#
# Committed WASMs in this repo (when present):
#   published-contract/web_container_contract.wasm  (paired with contract-id.txt)
#   published-contract/facade.wasm                  (paired with facade-id.txt; issue #200)
#
# The facade snapshot lives in published-contract/. CI rebuilds and
# byte-compares it on every PR (#206). See AGENTS.md §"Facade contract".
#
# Any other .wasm file showing up in a commit is almost certainly an
# accidental `target/` or `build/` artifact that slipped past .gitignore.

set -euo pipefail

ALLOWED_WEB_CONTAINER='published-contract/web_container_contract.wasm'
ALLOWED_FACADE='published-contract/facade.wasm'

# All staged .wasm files.
WASM_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.wasm' 2>/dev/null || true)

if [ -z "$WASM_FILES" ]; then
    exit 0
fi

# Filter out allowlisted committed WASMs.
STRAY=$(echo "$WASM_FILES" | grep -vE "^(${ALLOWED_WEB_CONTAINER}|${ALLOWED_FACADE})\$" || true)

if [ -z "$STRAY" ]; then
    # Each allowlisted WASM must be staged with its id.txt sibling so the
    # `id = hash(wasm, parameters)` invariant holds in the committed snapshot.
    if echo "$WASM_FILES" | grep -qx "$ALLOWED_WEB_CONTAINER"; then
        CONTRACT_ID_STAGED=$(git diff --cached --name-only -- published-contract/contract-id.txt 2>/dev/null || true)
        if [ -z "$CONTRACT_ID_STAGED" ]; then
            echo ""
            echo "🚫 BLOCKED: $ALLOWED_WEB_CONTAINER is staged"
            echo "   without published-contract/contract-id.txt."
            echo ""
            echo "The contract ID is hash(wasm, parameters); updating the WASM"
            echo "without refreshing contract-id.txt leaves the snapshot in a"
            echo "state where the committed ID no longer matches the committed WASM."
            echo ""
            echo "To fix:"
            echo "  cargo make update-published-contract"
            echo "  git add published-contract/"
            echo ""
            exit 1
        fi
    fi
    if echo "$WASM_FILES" | grep -qx "$ALLOWED_FACADE"; then
        FACADE_ID_STAGED=$(git diff --cached --name-only -- published-contract/facade-id.txt 2>/dev/null || true)
        if [ -z "$FACADE_ID_STAGED" ]; then
            echo ""
            echo "🚫 BLOCKED: $ALLOWED_FACADE is staged without published-contract/facade-id.txt."
            echo ""
            echo "The facade contract id is hash(facade.wasm, facade.parameters)"
            echo "and is supposed to stay STABLE across releases (issue #200)."
            echo "If the wasm legitimately changed, refresh both files together:"
            echo "  cargo make update-published-facade"
            echo "  git add published-contract/facade.{wasm,parameters} published-contract/facade-id.txt"
            echo ""
            echo "If the change was unintended, investigate which workspace dep"
            echo "leaked into facade.wasm and revert."
            echo ""
            exit 1
        fi
    fi
    exit 0
fi

echo ""
echo "🚫 BLOCKED: stray .wasm files are staged for commit outside published-contract/."
echo ""
echo "Staged stray WASM files:"
echo "$STRAY" | sed 's/^/  /'
echo ""
echo "Allowed committed WASMs:"
echo "  $ALLOWED_WEB_CONTAINER"
echo "  $ALLOWED_FACADE"
echo ""
echo "Everything else is a build artifact that should stay in target/ or"
echo "build/ (ignored by git)."
echo ""
echo "To unstage:"
echo "  git restore --staged <file>"
echo ""
exit 1
